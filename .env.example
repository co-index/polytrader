# ============================================================================
# polytrader 真钱交易凭证 —— 只存在你本机，已被 .gitignore 挡住，绝不会进代码库
# 填完保存即可，不用改代码。
# ============================================================================

# 【必填】钱包私钥（0x 开头的 64 位十六进制）
# - polymarket.com 邮箱注册的账号：设置 → Export Private Key 导出
# - 自建 MetaMask 钱包：账户详情 → 导出私钥
WALLET_PRIVATE_KEY=

# 【按注册方式二选一填写，自建钱包直连则都留空】
# polymarket.com 网站注册的账号需要填代理钱包地址（网站个人页显示的 0x 地址）：
POLY_FUNDER_ADDRESS=
# 签名类型：1 = 邮箱/Magic 注册的托管账号；2 = 用浏览器钱包登录网站创建的账号；
# 留空 = 自建钱包直连（不经 polymarket.com 网站）
POLY_SIGNATURE_TYPE=

# 【留空即可】CLOB 交易 API 凭证 —— 我会用你的私钥自动派生后回填
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# 【不用动】网络配置
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
