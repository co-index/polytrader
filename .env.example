# polytrader secrets. Copy to .env and fill in. NEVER commit .env.
# .env is gitignored; these are placeholders only.

# Polygon wallet private key used to sign orders (EIP-712). Keep this secret.
WALLET_PRIVATE_KEY=

# Polymarket CLOB API credentials (derive/create via the CLOB API).
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# CLOB endpoint and chain. Defaults shown.
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
