# polytrader 只读扫描服务配置 —— 复制为 /etc/polytrader/polytrader.env 后按需修改。
# 这里没有任何私钥/交易凭证:该服务是只读的,不下单,不需要钱包。

# 数据库路径(面板和扫描器共用,必须一致;install.sh 会指向 <安装目录>/data)
POLYTRADER_BASKET_DB=/opt/polytrader/data/basket.db
POLYTRADER_PAPER_DB=/opt/polytrader/data/paper.db

# 扫描节奏与阈值
POLYTRADER_SCAN_INTERVAL=300      # 每轮间隔秒数(300=5分钟;想省带宽可调 600/900)
POLYTRADER_SCAN_EDGE_MIN=0.005    # 记录机会的最小边际(0.005 = 0.5 美分/$1)
POLYTRADER_SCAN_MAX_EVENTS=250    # 每轮最多扫描的事件数(按 24h 成交量降序)

# 面板端口
POLYTRADER_DASHBOARD_PORT=8501
